module std.io;

import std.core.Enum;
import std.core.Filter;
import std.core.Iterator;
import std.core.FilterIter;
import std.encoding.utf8.decode;

pub interface Readable {
    fn read();
}

pub mixin Reader {
    pub fn readAll() {
        let buffSize = 1024;
        let mut output = [];

        for {
            let buff = this.read(buffSize);
            let len = buff.len();

            if len > 0 {
                output.append(buff);
            }

            if len < buffSize {
                return output;
            }
        }
    }

    pub fn readAllText() {
        let bytes = this.readAll();

        return decode(bytes);
    }
}

pub class File extends Reader {
    let fd;

    pub extern fn size();
    pub extern fn read(max);

    pub fn lines() -> LinesReader(reader: this);
}

extern fn openFileHandle(filename);

pub fn openFile(filename) -> File(fd: openFileHandle(filename));

pub class LinesIter {
    let reader;

    pub fn next() {
        let mut buff = [];

        for {
            let bytes = this.reader.read(1);

            if buff.len() == 0 && bytes.len() == 0 {
                return nil;
            }

            if bytes.first() == some(b'\n') {
                break;
            } else if bytes.len() == 0 {
                return some(decode(buff));
            }

            unsafe {
                buff.push(bytes[0]);
            }
        }

        return some(decode(buff));
    }
}

pub class LinesReader extends Iterator {
    let reader;

    pub fn iter() -> LinesIter(reader: this.reader);
}
